# ─────────────────────────────────────────────────────────────
# Supabase connection (client-side, safe to expose the PUBLISHABLE key)
# Copy this file to `.env` and fill in your project values.
# Find these in your Supabase dashboard → Project Settings → API.
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://vfyzedlyveukjaukcekq.supabase.co

# The PUBLISHABLE (anon) key. This is safe to ship in the browser because
# all access is guarded by the PIN-checked RPC functions + Row Level Security.
VITE_SUPABASE_ANON_KEY=sb_publishable_0rV81EKte4h5bhFyj6Nf4g_kDDLiDTD

# The tracker identifier (one row per student). Default: "yasmin".
VITE_TRACKER_ID=yasmin
